{
  "name": "darwinian",
  "bin": {
    "drwn": "cli/index.ts"
  },
  "exports": {
    "./hook-policy": {
      "types": "./cli/core/hook-policy/index.ts",
      "import": "./cli/core/hook-policy/index.ts",
      "default": "./cli/core/hook-policy/index.ts"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "description": "Local Darwinian Worker CLI for composing Cards, selecting one project Worker, and managing machine capabilities.",
  "version": "0.9.0",
  "license": "Apache-2.0",
  "author": "remyjkim <jkkim123@gmail.com>",
  "homepage": "https://github.com/remyjkim/darwinian-worker",
  "bugs": {
    "url": "https://github.com/remyjkim/darwinian-worker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remyjkim/darwinian-worker.git"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "files": [
    "cli",
    "registry",
    "skills",
    "README.md",
    "docs/assets/darwinian-worker-logo.png",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "darwinian",
    "drwn",
    "mind",
    "harness",
    "meta-harness",
    "agents",
    "mcp",
    "skills",
    "cli",
    "configuration"
  ],
  "scripts": {
    "drwn": "bun run cli/index.ts",
    "test": "bun test ./test/",
    "typecheck": "tsc --noEmit",
    "verify:release": "bun run scripts/verify-release-readiness.ts",
    "verify:bridge": "bun run --cwd drwn-command-bridge verify",
    "docs:dev": "cd docs-docusaurus && bun run start",
    "docs:build": "cd docs-docusaurus && bun run build",
    "docs:deploy": "cd docs-docusaurus && bun run deploy:pages"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "clipanion": "4.0.0-rc.4",
    "drwn-catalog-schema": "^0.1.0",
    "semver": "^7.8.0",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.19",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  }
}
